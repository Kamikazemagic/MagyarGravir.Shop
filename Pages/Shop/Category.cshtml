@page
@model MagyarGravir.Shop.Pages.Shop.CategoryModel
@{
    ViewData["Title"] = Model.CurrentCategory?.Name ?? "Kategóriák";
}

<h1 class="mg-section-title">@Model.CurrentCategory?.Name</h1>

@if (Model.Products.Count == 0)
{
    <p class="text-light">Nincs megjeleníthető termék ebben a kategóriában.</p>
}
else
{
    <div class="mg-product-grid">
        @foreach (var p in Model.Products)
        {
            <a href="/Shop/Product?id=@p.Id" class="mg-product-card" target="_blank" rel="noopener noreferrer">
                <div class="mg-product-img">
                    <img src="@p.MainImagePath" alt="@p.Name" />
                </div>
                <div class="mg-product-name">@p.Name</div>
                <div class="mg-price">@p.Price Ft</div>
            </a>
        }
    </div>
}