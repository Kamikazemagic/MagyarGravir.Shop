@page
@model MagyarGravir.Shop.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Admin belépés";
}

<div class"login-body">
    <div class="login-box">
        <h2>Admin belépés</h2>

        <form method="post">
            <input asp-for="Username" class="login-input" placeholder="Felhasználónév" />
            <input asp-for="Password" type="password" class="login-input" placeholder="Jelszó" />

            <button type="submit" class="login-btn">Belépés</button>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error">@Model.ErrorMessage</div>
            }
        </form>
    </div>
</div>