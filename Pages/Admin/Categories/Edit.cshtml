@page
@model MagyarGravir.Shop.Pages.Admin.Categories.EditModel
@{
    ViewData["Title"] = "Admin - Kategória szerkesztése";
}

<h1>Kategória szerkesztése</h1>

    <form method="post">
        <input type="hidden" asp-for="EditCategory.Id" />

        <label>
            Kategória neve:
            <input asp-for="EditCategory.Name" />
        </label>

        <label>
            Egyedi kategória?
            <input asp-for="EditCategory.IsCustom" type="checkbox" />
        </label>

        <button>Mentés</button>
           
    </form>

<a href="/Admin/Categories" class="back">← Vissza</a>