@page
@model MagyarGravir.Shop.Pages.Account.RegisterModel

<link rel="stylesheet" href="~/css/Register.css" />

<div class="card">
    <h2>Regisztráció</h2>

    <form method="post" autocomplete="off">
        <input asp-for="Username" placeholder="Felhasználónév" required autocomplete="off" />
        <input asp-for="Email" placeholder="Email" type="email" required autocomplete="off" />

        <div class="password-wrapper">
            <input id="Password" asp-for="Password" placeholder="Jelszó" type="password" required autocomplete="new-password" />
            <span class="toggle-password" onclick="togglePassword('Password', this)">👁️</span>
        </div>

        <div class="password-wrapper">
            <input id="ConfirmPassword" asp-for="ConfirmPassword" placeholder="Jelszó újra" type="password" required autocomplete="new-password" />
            <span class="toggle-password" onclick="togglePassword('ConfirmPassword', this)">👁️</span>
        </div>

        <input asp-for="ZipCode" placeholder="Irányítószám" required autocomplete="off" />
        <input asp-for="City" placeholder="Város" required autocomplete="off" />
        <input asp-for="Street" placeholder="Utca, házszám" required autocomplete="off" />

        <button type="submit">Regisztráció</button>
    </form>

    @if (TempData["Error"] != null)
    {
        <p style="color:red;">@TempData["Error"]</p>
    }
    @if (TempData["Message"] != null)
    {
        <p style="color:green;">@TempData["Message"]</p>
    }
</div>

<script>
function togglePassword(inputId, icon) {
    const pw = document.getElementById(inputId);
    if (pw.type === "password") {
        pw.type = "text";
        icon.textContent = "🙈"; // jelszó látható
    } else {
        pw.type = "password";
        icon.textContent = "👁️"; // jelszó elrejtve
    }
}
</script>
