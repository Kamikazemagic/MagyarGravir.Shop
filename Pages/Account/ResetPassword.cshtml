@page
@model MagyarGravir.Shop.Pages.Account.ResetPasswordModel

<h2>Új jelszó</h2>

<form method="post">
    <input type="hidden" asp-for="Token" />
    <input asp-for="NewPassword" type="password" placeholder="Új jelszó" required />
    <button type="submit">Mentés</button>
</form>

@if (Model.Message != null)
{
    <p>@Model.Message</p>
}